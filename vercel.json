{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.temptmotorsports.com" }],
      "destination": "https://temptmotorsports.com/:path*",
      "permanent": true
    },
    {
      "source": "/pre-approval",
      "destination": "/apply",
      "permanent": true
    },
    {
      "source": "/pre-approval/complete",
      "destination": "/apply/complete",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!assets/)(?!api/)(?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
