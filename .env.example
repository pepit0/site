# Supabase project for THIS app only (Settings → API). Use a different project than the finance CRM if you want
# separate Auth users.
VITE_SUPABASE_URL=
# Use the Publishable key (sb_publishable_...) from Settings → API Keys. If legacy keys are disabled, the old
# JWT "anon" key (eyJ...) will not work — either paste the publishable key here or re-enable legacy keys in Supabase.
VITE_SUPABASE_ANON_KEY=

# Set to true when the site uses its own Supabase project (no shared CRM users / no user_has_crm_access RPC here).
# Hides the CRM "Staff" nav link; sign-in is still used for /admin/inventory (run sql/marketing/*.sql + inventory_admins).
VITE_SITE_MARKETING_ONLY=true

# Public site URL (no trailing slash). Used for canonical, Open Graph, and prebuild sitemap/robots.
# Example: https://temptationmotorsports.com
VITE_PUBLIC_SITE_URL=

# Optional: match Google Business Profile exactly for richer LocalBusiness JSON-LD (omit if unknown).
# VITE_PUBLIC_BUSINESS_STREET_ADDRESS=123 Main St
# VITE_PUBLIC_BUSINESS_POSTAL_CODE=T5J 0K1
# Comma-separated profile URLs (Facebook, Maps listing, etc.)
# VITE_PUBLIC_BUSINESS_SAME_AS=https://www.facebook.com/yourpage,https://maps.app.goo.gl/yourlisting

# Bulk MSF import script only (never ship to the browser): npm run msf:queue
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# In Supabase → SQL Editor, set role to **postgres**, then run sql/marketing/01_inventory_units.sql then sql/marketing/02_storage_inventory_photos.sql (if "permission denied for schema public", run sql/marketing/00_public_schema_for_owner.sql first as postgres).

# Pre-approval form: run sql/marketing/04_submit_public_preapproval_lead.sql on THIS project (creates RPC + table).
# Or use crm_public_preapproval_leads_marketing_project.sql from the finance CRM repo—pick one coherent setup.

# Optional: absolute URL of the finance CRM for internal bookmarks (not used when marketing-only).
# VITE_CRM_APP_URL=http://localhost:5174
