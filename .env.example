# Supabase project for THIS app only (Settings → API). Use a different project than the finance CRM if you want
# separate Auth users.
VITE_SUPABASE_URL=
# Use the Publishable key (sb_publishable_...) from Settings → API Keys. If legacy keys are disabled, the old
# JWT "anon" key (eyJ...) will not work — either paste the publishable key here or re-enable legacy keys in Supabase.
VITE_SUPABASE_ANON_KEY=

# Set to true when the site uses its own Supabase project (no shared CRM users / no user_has_crm_access RPC here).
# Hides the CRM "Staff" nav link; sign-in is still used for /admin/inventory (run sql/marketing/*.sql + inventory_admins).
VITE_SITE_MARKETING_ONLY=true

# Public site URL (no trailing slash). Used for canonical, Open Graph, and prebuild sitemap/robots.
# Example: https://temptationmotorsports.com
VITE_PUBLIC_SITE_URL=

# Optional: match Google Business Profile exactly for richer LocalBusiness JSON-LD (omit if unknown).
# VITE_PUBLIC_BUSINESS_STREET_ADDRESS=123 Main St
# VITE_PUBLIC_BUSINESS_POSTAL_CODE=T5J 0K1
# Comma-separated profile URLs (Facebook, Maps listing, etc.)
# VITE_PUBLIC_BUSINESS_SAME_AS=https://www.facebook.com/yourpage,https://maps.app.goo.gl/yourlisting

# MSF import queue: Admin → MSF import → "Import new units" (Edge Function sync-msf-import-queue).
# Deploy once from project root (do NOT use npm install -g supabase):
#   1) npm run supabase:login  → at "Press Enter", press Enter ONLY (finish browser login first)
#   2) npm run supabase:link -- --project-ref YOUR_PROJECT_REF
#   3) npm run supabase:deploy-msf
# YOUR_PROJECT_REF = id in https://supabase.com/dashboard/project/<that-id>
# Optional local script (service role, never in browser): npm run msf:queue
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# In Supabase → SQL Editor, set role to **postgres**, then run sql/marketing/01_inventory_units.sql then sql/marketing/02_storage_inventory_photos.sql (if "permission denied for schema public", run sql/marketing/00_public_schema_for_owner.sql first as postgres).

# Pre-approval form: run sql/marketing/04_submit_public_preapproval_lead.sql on THIS project (creates RPC + table).
# Or use crm_public_preapproval_leads_marketing_project.sql from the finance CRM repo—pick one coherent setup.

# Optional: absolute URL of the finance CRM for internal bookmarks (not used when marketing-only).
# VITE_CRM_APP_URL=http://localhost:5174

# Live chat (Tawk.to) + site intake (name → unit pick → Tawk chat).
# Tawk embed path: Administration → Channels → Chat Widget → copy Property ID and Widget ID.
# Either set both below, or a single value: propertyId/widgetId
# VITE_TAWK_PROPERTY_ID=your_property_id/your_widget_id
# VITE_TAWK_WIDGET_ID=
# VITE_PUBLIC_SITE_URL must be your live domain so chat unit links are absolute.
#
# Setup checklist:
# A) Vercel — VITE_TAWK_PROPERTY_ID + VITE_PUBLIC_SITE_URL, then redeploy.
# B) Supabase (postgres) — sql/marketing/20_chat_leads.sql then 21_chat_leads_unit_message.sql
#
# Tawk: you when Online, AI when Away/Offline
# 1) Dashboard → your profile → set status Online only when you can reply yourself.
#    Away/Offline routes visitors to AI Assist (not you).
# 2) Add-ons → AI Assist → enable for this property → pick/create an agent.
# 3) Train the bot (AI Assist → your agent):
#    - Knowledge: paste site FAQs, financing steps, hours, phone (587) 741-1945, pre-approval URL.
#    - Website: add https://your-domain.com so it can read inventory/pages.
#    - Escalation: when visitor asks for a human, use a shortcut that explains hours + email/callback.
# 4) AI Assist → Settings → deploy to Live Chat widget (same widget as VITE_TAWK_PROPERTY_ID).
# 5) Administration → Chat Widget → disable duplicate pre-chat form if the site already collects name/phone.
#    Visitor name/phone/unit are passed from the site via setAttributes (unit-interest, unit-id).
# 6) Mobile app: notifications when Online; test Away to confirm the bot answers.
#
# Match Tawk widget colors to the site (see src/lib/chatTheme.ts for hex values):
#   Administration → Channels → Chat Widget → Appearance → Advanced
#   Header bg #181b22 | Chat bg #12141a | Accent/button #f05d22 | Text #e8eaef
#   Visitor bubbles #1e222c | Agent bubbles #f05d22 with white text
#   Position: bottom-right (same as site chat). Upload Tlogo if offered.
# 7) AI Assist → Base Prompt: append TAWK_AI_UNIT_CONTEXT_PROMPT from src/lib/chatTheme.ts
# 8) Automation → trigger on event "website-unit-selected" → AI message mentioning the unit
#    (see TAWK_AUTOMATION_UNIT_EVENT in src/lib/chatTheme.ts). Sidebar attributes alone are not enough for the bot.
